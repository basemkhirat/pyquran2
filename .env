#####################
# Backend variables #
#####################

# Path to the Hugging Face Whisper model for speech-to-text.
HF_MODEL_PATH=./models/whisper-quran-v1
# HF_MODEL_PATH=./models/tarbiyah-ai-v1-1

# Path to Hafs narration JSON: reference Quran text used for scoring and correction.
HAFS_JSON_PATH=./assets/narrations/hafs.json

# Weight for character-level score (0–1). text_score = WEIGHT_CHAR * char_score + WEIGHT_DIACRITIC * diacritic_score.
WEIGHT_CHAR=0.75

# Weight for diacritic (tashkeel) score (0–1). WEIGHT_CHAR + WEIGHT_DIACRITIC should sum to 1.0.
WEIGHT_DIACRITIC=0.25

# Minimum total score (0–1) for a segment to be marked correct; below this is incorrect.
SCORE_THRESHOLD=0.76

# When true, mark word correct if EITHER text_score OR acoustic_score exceeds SCORE_THRESHOLD (default: false).
PASS_ON_ANY_SCORE=false

# Milliseconds of silence after speech before ending the current recording segment (VAD).
SILENCE_TIMEOUT_MS=200

# Sample rate (Hz) for recording and processing audio; 16000 is standard for Whisper.
AUDIO_SAMPLE_RATE=16000

# Max Levenshtein edits allowed to auto-correct a transcribed word to the expected word; above this, transcription is kept.
MAX_EDITS_FOR_CORRECTION=2

# text scorer (whisper transcription)
ENABLE_TEXT_SCORE=false
WEIGHT_TEXT=0.5

# acoustic scorer
ENABLE_ACOUSTIC_SCORE=true
WEIGHT_ACOUSTIC=0.5
#WAV2VEC2_QURAN_ASR_MODEL=HamzaSidhu786/wav2vec2-base-word-by-word-quran-asr
#WAV2VEC2_QURAN_ASR_MODEL=jonatasgrosman/wav2vec2-large-xlsr-53-arabic
WAV2VEC2_QURAN_ASR_MODEL=rabah2026/wav2vec2-large-xlsr-53-arabic-quran-v_final

# When set, socket connections require this key in handshake auth.api_key.
SOCKET_AUTH_API_KEY=mWrhEBxIUstdokyV5FynGaqN0zowUYaCFvW88RdzYeY

HF_TOKEN=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

# Interval in ms between streaming transcription runs during speech.
STREAMING_INTERVAL_MS=600
# Minimum audio buffer (seconds) before first streaming transcription.
STREAMING_MIN_AUDIO_SEC=1

# When True, persist data.json and recording.wav to data/sessions/{uuid}/ in background (non-blocking)
SAVE_SESSION_DATA=false

# Which diacritics count toward the diacritic score (and are kept during acoustic scoring).
# Set any to false to ignore that mark everywhere. All default to true.
SCORE_FATHA=true
SCORE_DAMMA=true
SCORE_KASRA=true
SCORE_SHADDA=true
SCORE_SUKOON=false



# --- Verse detection (which verse the user starts reciting) ---
# Minimum alignment score (0–1) to confirm a start verse.
VERSE_DETECTION_THRESHOLD=0.7
# Upper cap on words compared when the utterance is long (short utterances use their own length).
VERSE_DETECTION_WORD_COUNT=4
# Candidates within this score margin of the best are treated as a tie. When identical verses
# (e.g. Al-Rahman's refrain) tie, detection stays "ambiguous" and waits for the next distinct
# verse instead of guessing the wrong occurrence.
VERSE_DETECTION_TIE_EPSILON=0.10