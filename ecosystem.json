{
  "apps": [
    {
      "name": "pyquran-backend",
      "script": "make",
      "args": "backend",
      "interpreter": "none",
      "cwd": "./",
      "watch": false,
      "autorestart": true,
      "max_restarts": 999999999,
      "restart_delay": 2000,
      "kill_timeout": 10000,
      "time": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
