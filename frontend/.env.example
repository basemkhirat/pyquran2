# Single backend URL for both Socket.IO and REST API. Use URL from modal serve (-dev) or modal deploy.
# Unset or leave empty in dev to use http://localhost:8000.
# VITE_BACKEND_URL=https://your-workspace--your-app-serve-dev.modal.run
# VITE_BACKEND_URL=https://websocket.example.com

# Frontend sends this as auth.api_key when connecting (must match backend SOCKET_AUTH_API_KEY).
# VITE_SOCKET_API_KEY=
